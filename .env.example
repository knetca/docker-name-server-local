# docker-dns — environment configuration
# Copy to .env and fill in values. .env is never committed.

# --- Alpine base tag ---
# All three images (unbound, chrony, dns-manager) are built from this tag.
# Update here to rebuild all images on the same base.
ALPINE_TAG=3.20

# --- Timezone ---
TZ=America/Toronto

# --- Zone repo ---
# SSH URL of the dedicated zones git repository.
ZONES_REPO=git@github.com:you/dns-zones.git

# Branch to track
ZONES_BRANCH=main

# Cron schedule for zone polling (default: every 5 minutes)
ZONES_CRON=*/5 * * * *

# --- Blocklist ---
# Cron schedule for OISD blocklist fetch (default: daily 03:00)
BLOCKLIST_CRON=0 3 * * *
