# docker-dns — environment configuration
# Copy to .env and fill in values. .env is never committed.

# --- Alpine base tag ---
# All three images (unbound, chrony, dns-manager) are built from this tag.
# Update here to rebuild all images on the same base.
ALPINE_TAG=3.21

# --- Timezone ---
TZ=America/Toronto

# --- Zone repo ---
# SSH URL of the dedicated zones git repository.
ZONES_REPO=git@github.com:you/dns-zones.git

# Branch to track
ZONES_BRANCH=main

# Cron schedule for zone polling (default: every 5 minutes)
ZONES_CRON=*/5 * * * *

# --- Blocklist ---
# Cron schedule for blocklist fetch (default: daily 03:00)
BLOCKLIST_CRON=0 3 * * *

# Minimum line count — fetch is rejected if below this threshold
BLOCKLIST_MIN_LINES=10000

# Jitter max seconds — random delay added to blocklist fetch time to avoid
# thundering herd (default: 60)
JITTER_MAX=60

# URL of a blocklist in native Unbound local-data format.
# Leave empty to disable blocklisting entirely. Any existing blocklist file
# will be removed and Unbound reloaded on the next scheduled run.
#
# OISD tiers (all in native Unbound format):
#   big   — full (ads, trackers, malware, phishing, adult) — most aggressive
#   small — conservative (ads, trackers, malware, phishing) — lower false-positive rate
#   nsfw  — adult content only — combine with big or small
#
BLOCKLIST_URL=https://big.oisd.nl/unbound

# Example — conservative tier:
# BLOCKLIST_URL=https://small.oisd.nl/unbound

# Example — disabled:
# BLOCKLIST_URL=
