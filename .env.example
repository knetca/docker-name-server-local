# docker-name-server — environment configuration
# Copy to .env and fill in values. .env is never committed.

# --- Image tags ---
UNBOUND_TAG=1.22.0
CHRONY_TAG=4.6.1
ALPINE_TAG=3.20

# dns-manager is built locally. Tag is used to identify the local image.
# Increment when rebuilding after Dockerfile or script changes.
MANAGER_TAG=1.0.0

# --- Timezone ---
TZ=America/Toronto

# --- Zone repo ---
# SSH URL of the dedicated zones git repository.
ZONES_REPO=git@github.com:you/dns-zones.git

# Branch to track
ZONES_BRANCH=main

# Cron schedule for zone polling (default: every 5 minutes)
ZONES_CRON=*/5 * * * *

# --- Blocklist ---
# Cron schedule for OISD blocklist fetch (default: daily 03:00)
BLOCKLIST_CRON=0 3 * * *
